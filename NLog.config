<?xml version="1.0" encoding="utf-8" ?>
<nlog xmlns="http://www.nlog-project.org/schemas/NLog.xsd"
      xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:schemaLocation="http://www.nlog-project.org/schemas/NLog.xsd NLog.xsd"
      autoReload="true"
      throwExceptions="false"
      internalLogLevel="Off" internalLogFile="c:\temp\nlog-internal.log">

	<!-- Цели (куда пишем логи) -->
	<targets>
		<!-- Лог в файл -->
		<target name="logfile" xsi:type="File"
				fileName="logs/${shortdate}.log"
				layout="${longdate} [${level:uppercase=true}] ${logger} - ${message} ${exception:format=toString}"
				archiveAboveSize="10485760"
				maxArchiveFiles="10"
				encoding="utf-8" />

		<!-- Лог в консоль (если нужно) -->
		<target name="console" xsi:type="Console"
				layout="${longdate} [${level:uppercase=true}] ${message}" />

		<!-- Лог в окно отладки Visual Studio -->
		<target name="debugger" xsi:type="Debugger"
				layout="${longdate} [${level:uppercase=true}] ${logger} - ${message}" />
	</targets>

	<!-- Правила (какие уровни логировать) -->
	<rules>
		<!-- Логируем всё от Debug и выше в файл -->
		<logger name="*" minlevel="Debug" writeTo="logfile" />

		<!-- Логируем ошибки и выше в консоль -->
		<logger name="*" minlevel="Error" writeTo="console" />

		<!-- Логируем всё в окно отладки (только при отладке) -->
		<logger name="*" minlevel="Trace" writeTo="debugger" />
	</rules>
</nlog>